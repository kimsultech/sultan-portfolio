---
import { type Locale, useTranslations } from "../utils/i18n";

interface Props {
  href: string;
  images: string[];
  title: string;
  description: string;
  team?: Array<{ name: string; role: string; avatar: string; linkedIn?: string }>;
  locale: Locale;
  publishedAt: string;
  tags?: string[];
  categories?: string[];
}

const { href, images = [], title, description, team = [], locale, publishedAt, tags = [], categories = [] } = Astro.props;
const t = useTranslations(locale);

const firstImage = images.length > 0 ? images[0] : "/images/cover.png";

// Formatter for date
const formatDate = (dateStr: string) => {
  try {
    const date = new Date(dateStr);
    return date.toLocaleDateString(locale === "en" ? "en-US" : "id-ID", {
      year: "numeric",
      month: "short"
    });
  } catch (e) {
    return dateStr;
  }
};
---

<div 
  class="card md:card-side bg-base-200 border border-base-300 shadow-md hover:shadow-xl hover:border-primary/30 transition-all duration-300 group overflow-hidden mb-8"
  data-project-card
  data-categories={categories.join(" ")}
>
  <!-- Cover Image Container -->
  <figure class="md:w-2/5 aspect-[16/10] md:aspect-auto relative overflow-hidden bg-base-300 min-h-[220px]">
    <img 
      src={firstImage} 
      alt={title} 
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
      loading="lazy"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-base-900/40 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
  </figure>

  <!-- Content Block -->
  <div class="card-body md:w-3/5 p-6 md:p-8 flex flex-col justify-between">
    <div>
      <div class="flex items-center justify-between gap-4 mb-2">
        <span class="text-xs font-bold text-primary/80 uppercase tracking-wider">
          {formatDate(publishedAt)}
        </span>
        
        <!-- Team Avatars -->
        {team.length > 0 && (
          <div class="avatar-group -space-x-2.5 rtl:space-x-reverse">
            {team.map(member => (
              <div class="avatar w-5.5 h-5.5 border border-base-200" title={`${member.name} - ${member.role}`}>
                <img src={member.avatar} alt={member.name} />
              </div>
            ))}
          </div>
        )}
      </div>

      <h2 class="card-title text-xl md:text-2xl font-black text-base-content group-hover:text-primary transition-colors mb-2.5">
        {title}
      </h2>
      
      <p class="text-base-content/75 text-xs line-clamp-3 leading-relaxed mb-4">
        {description}
      </p>

      <!-- Skill Tag Badges -->
      {tags.length > 0 && (
        <div class="flex flex-wrap gap-1.5 mt-2">
          {tags.map(tag => (
            <span class="badge badge-sm badge-outline border-base-300 text-base-content/70 rounded-md font-semibold text-[10px]">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>

    <div class="card-actions justify-start mt-6 pt-4 border-t border-base-300/40">
      <a href={href} class="btn btn-primary btn-sm gap-2 rounded-lg text-xs font-bold px-4">
        {t("projectCard.label")}
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3" />
        </svg>
      </a>
    </div>
  </div>
</div>
